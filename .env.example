# Paths are relative to the project root (study_workflow_app/) unless absolute.
APP_DATA_DIR=./data
COURSES_STORAGE_DIR=./courses
DATABASE_PATH=./data/app.db

# Secret for signing session cookies (per-browser API keys in Settings). Use a long random string in production.
SESSION_SECRET=

# Railway / reverse proxy: uvicorn trusts X-Forwarded-Proto when set (Procfile uses FORWARDED_ALLOW_IPS=*).
# FORWARDED_ALLOW_IPS=*

# Optional — required only for "Generate study materials" (OpenAI) unless each tester sets a key in Settings
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model name your account supports (default below is widely available)
OPENAI_MODEL=gpt-4o-mini
